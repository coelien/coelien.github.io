    <title>目标识别</title>
    <link href="http://example.com/2021/12/23/CV%E5%9B%BE%E5%83%8F%E5%AF%B9%E9%BD%90&amp;%E5%9B%BE%E5%83%8F%E6%8B%BC%E6%8E%A5/"/>
    <id>http://example.com/2021/12/23/CV%E5%9B%BE%E5%83%8F%E5%AF%B9%E9%BD%90&amp;%E5%9B%BE%E5%83%8F%E6%8B%BC%E6%8E%A5/</id>
    <published>2021-12-23T11:34:59.881Z</published>
